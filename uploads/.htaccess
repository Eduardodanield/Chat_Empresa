# ══════════════════════════════════════════════════════
#  SEGURANÇA — pasta uploads/
#  Impede execução de qualquer script dentro desta pasta
# ══════════════════════════════════════════════════════

# Bloqueia execução de PHP
<FilesMatch "\.php[0-9]?$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Bloqueia execução de outros tipos perigosos
<FilesMatch "\.(php|php3|php4|php5|php7|phtml|phar|pl|py|cgi|sh|exe|bat|cmd|asp|aspx|jsp)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Desativa CGI e SSI nesta pasta
Options -ExecCGI -Includes

# Se o mod_php estiver ativo, garante que não execute scripts
<IfModule mod_php.c>
    php_flag engine off
</IfModule>
